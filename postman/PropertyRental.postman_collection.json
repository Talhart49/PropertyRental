        {
          "name": "Get Incoming Bookings (Landlord)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => { pm.response.to.have.status(200); });",
                  "pm.test('Returns incoming bookings', () => {",
                  "  pm.expect(pm.response.json().data.bookings).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{landlordToken}}" }
            ],
            "url": "{{baseUrl}}/api/bookings/incoming"
          }
        },
        {
          "name": "Approve Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => { pm.response.to.have.status(200); });",
                  "pm.test('Booking approved', () => {",
                  "  pm.expect(pm.response.json().data.booking.status).to.eql('approved');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{landlordToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\",\n  \"landlordResponse\": \"Looking forward to showing you around!\"\n}"
            },
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}/status"
          }
        }
      ]
    },
